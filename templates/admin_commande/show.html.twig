{% extends 'admin_base.html.twig' %}
{% block title %}Détail commande admin{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_admin_commande_index') }}" class="btn btn-outline-secondary mb-4">
        Retour aux commandes
    </a>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Commande {{ commande.numero }}</h4>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">Informations commande</h5>

                    <p><strong>Numéro :</strong> {{ commande.numero }}</p>
                    <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>
                    <p><strong>Total :</strong> {{ commande.total }} DT</p>
                    <p><strong>Mode paiement :</strong> {{ commande.modePaiement }}</p>

                    <p>
                        <strong>Paiement :</strong>
                        {% if commande.etat == 'annulee' %}
                            <span class="badge bg-secondary">Remboursée</span>
                        {% elseif commande.isPaid %}
                            <span class="badge bg-success">Payée</span>
                        {% else %}
                            <span class="badge bg-danger">Non payée</span>
                        {% endif %}
                    </p>
                                    </div>

                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">Client</h5>

                    {% if commande.user %}
                        <p><strong>Nom :</strong> {{ commande.user.nom }} {{ commande.user.prenom }}</p>
                        <p><strong>Email :</strong> {{ commande.user.email }}</p>
                        <p><strong>Téléphone :</strong> {{ commande.user.telephone ?: '-' }}</p>
                        <p><strong>Adresse :</strong> {{ commande.user.adresse ?: '-' }}</p>
                    {% else %}
                        <div class="alert alert-warning">
                            Client introuvable.
                        </div>
                    {% endif %}
                </div>
            </div>

            <hr>

            <h5 class="fw-bold mb-3">Changer l'état de la commande</h5>

            <form method="post"
                  action="{{ path('app_admin_commande_etat', {'id': commande.id}) }}"
                  class="row g-3 align-items-end">

                <input type="hidden" name="_token" value="{{ csrf_token('etat' ~ commande.id) }}">

                <div class="col-md-6">
                    <label class="form-label">État</label>

                    <select name="etat" class="form-select">
                        <option value="en_attente" {% if commande.etat == 'en_attente' %}selected{% endif %}>
                            En attente
                        </option>

                        <option value="confirmee" {% if commande.etat == 'confirmee' %}selected{% endif %}>
                            Confirmée
                        </option>

                        <option value="annulee" {% if commande.etat == 'annulee' %}selected{% endif %}>
                            Annulée
                        </option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button class="btn btn-success w-100">
                        Modifier
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Produits commandés</h5>
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Produit</th>
                        <th>Catégorie</th>
                        <th>Prix unitaire</th>
                        <th>Quantité</th>
                        <th>Sous-total</th>
                    </tr>
                </thead>

                <tbody>
                    {% for ligne in commande.ligneCommandes %}
                        <tr>
                            <td>
                                <strong>{{ ligne.meuble.nom }}</strong>
                            </td>

                            <td>
                                {% if ligne.meuble.categorie %}
                                    {{ ligne.meuble.categorie.nom }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>

                            <td>{{ ligne.prixUnitaire }} DT</td>
                            <td>{{ ligne.quantite }}</td>
                            <td>{{ ligne.sousTotal }} DT</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                Aucun produit dans cette commande.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>

                <tfoot>
                    <tr>
                        <th colspan="4" class="text-end">Total</th>
                        <th>{{ commande.total }} DT</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>
{% endblock %}