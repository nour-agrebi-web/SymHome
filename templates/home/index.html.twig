{% extends 'base.html.twig' %}

{% block title %}Nos produits - SymHome{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: #fff;
    }

    .products-header {
        margin-bottom: 30px;
    }

    .products-header h1 {
        color: #2b2118;
        font-size: 48px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .products-header p {
        color: #6f6257;
        font-size: 20px;
        max-width: 760px;
    }

    .filter-card {
        border: 1px solid #eadfd5;
        border-radius: 18px;
        box-shadow: 0 10px 26px rgba(0, 0, 0, 0.06);
    }

    .section-title {
        color: #2b2118;
        font-weight: 900;
    }

    .product-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
    }

    .product-img {
        height: 220px;
        object-fit: cover;
    }

    .placeholder-img {
        height: 220px;
        background: #f4eee8;
        color: #8b5e3c;
    }

    .price {
        color: #8b5e3c;
        font-weight: 900;
    }

    .btn-symhome {
        background: #8b5e3c;
        color: #fff;
        border: none;
    }

    .btn-symhome:hover {
        background: #70482d;
        color: #fff;
    }

    .btn-outline-symhome {
        border: 1px solid #8b5e3c;
        color: #8b5e3c;
    }

    .btn-outline-symhome:hover {
        background: #8b5e3c;
        color: #fff;
    }

    .badge-category {
        background: #f3eee8;
        color: #70482d;
    }

    @media (max-width: 768px) {
        .products-header h1 {
            font-size: 34px;
        }

        .products-header p {
            font-size: 17px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="products-header">
        <h1>Nos produits</h1>
        <p>
            Découvrez tous les meubles disponibles chez SymHome.
        </p>
    </div>

    <section id="produits">
        <div class="card filter-card mb-4">
            <div class="card-body">
                <form method="get" action="{{ path('app_produit_index') }}" class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Recherche par nom</label>
                        <input type="text"
                               name="search"
                               value="{{ search }}"
                               class="form-control"
                               placeholder="Ex: canapé, chaise, bureau...">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Catégorie</label>
                        <select name="categorie" class="form-select">
                            <option value="">Toutes les catégories</option>

                            {% for categorie in categories %}
                                <option value="{{ categorie.id }}"
                                    {% if categorieId == categorie.id %}selected{% endif %}>
                                    {{ categorie.nom }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-symhome w-100">
                            Rechercher
                        </button>

                        <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="row">
            {% for meuble in meubles %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm product-card">

                        {% if meuble.image %}
                            <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                                 class="card-img-top product-img"
                                 alt="{{ meuble.nom }}">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center placeholder-img">
                                <span>Aucune image</span>
                            </div>
                        {% endif %}

                        <div class="card-body">
                            {% if meuble.categorie %}
                                <span class="badge badge-category mb-2">
                                    {{ meuble.categorie.nom }}
                                </span>
                            {% endif %}

                            <h5 class="card-title fw-bold">{{ meuble.nom }}</h5>

                            <p class="card-text text-muted">
                                {% if meuble.description %}
                                    {{ meuble.description|slice(0, 80) }}
                                    {% if meuble.description|length > 80 %}...{% endif %}
                                {% else %}
                                    Aucune description
                                {% endif %}
                            </p>

                            <p class="fs-5 price">
                                {{ meuble.prix }} DT
                            </p>

                            {% if meuble.stock > 0 %}
                                <span class="badge bg-success">En stock: {{ meuble.stock }}</span>
                            {% else %}
                                <span class="badge bg-danger">Rupture de stock</span>
                            {% endif %}
                        </div>

                        <div class="card-footer bg-white d-flex justify-content-between">
                            <a href="{{ path('app_produit_show', {'id': meuble.id}) }}" class="btn btn-sm btn-outline-symhome">
                                Voir détail
                            </a>

                            {% if app.user %}
                                <a href="{{ path('app_panier_ajouter', {'id': meuble.id}) }}" class="btn btn-sm btn-symhome">
                                    Ajouter au panier
                                </a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="btn btn-sm btn-symhome">
                                    Ajouter au panier
                                </a>
                            {% endif %}
                        </div>

                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">
                        Aucun meuble disponible pour le moment.
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>

</div>
{% endblock %}