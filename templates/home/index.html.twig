{% extends 'base.html.twig' %}

{% block title %}Accueil - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="p-5 mb-5 bg-light rounded-3 shadow-sm">
        <div class="container-fluid py-4">
            <h1 class="display-5 fw-bold">Bienvenue chez SymHome</h1>
            <p class="col-md-8 fs-5">
                Découvrez notre collection de meubles et décoration pour votre maison.
            </p>

            <a href="#produits" class="btn btn-primary btn-lg">
                Voir les meubles
            </a>
        </div>
    </div>

    <section id="produits">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Nos meubles</h2>
                <p class="text-muted">Catalogue des meubles disponibles.</p>
            </div>

            <a href="{{ path('app_meuble_index') }}" class="btn btn-outline-dark">
                Administration
            </a>
        </div>

        <div class="row">
            {% for meuble in meubles %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">

                        {% if meuble.image %}
                            <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                                 class="card-img-top"
                                 alt="{{ meuble.nom }}"
                                 style="height: 220px; object-fit: cover;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height: 220px;">
                                <span class="text-muted">Aucune image</span>
                            </div>
                        {% endif %}

                        <div class="card-body">
                            {% if meuble.categorie %}
                                <span class="badge bg-secondary mb-2">
                                    {{ meuble.categorie.nom }}
                                </span>
                            {% endif %}

                            <h5 class="card-title">{{ meuble.nom }}</h5>

                            <p class="card-text text-muted">
                                {% if meuble.description %}
                                    {{ meuble.description|slice(0, 80) }}
                                    {% if meuble.description|length > 80 %}...{% endif %}
                                {% else %}
                                    Aucune description
                                {% endif %}
                            </p>

                            <p class="fw-bold text-primary fs-5">
                                {{ meuble.prix }} DT
                            </p>

                            {% if meuble.stock > 0 %}
                                <span class="badge bg-success">En stock: {{ meuble.stock }}</span>
                            {% else %}
                                <span class="badge bg-danger">Rupture de stock</span>
                            {% endif %}
                        </div>

                        <div class="card-footer bg-white d-flex justify-content-between">
                            <a href="{{ path('app_produit_show', {'id': meuble.id}) }}" class="btn btn-sm btn-outline-primary">
                                Voir détail
                            </a>

                            <a href="#" class="btn btn-sm btn-success">
                                Ajouter au panier
                            </a>
                        </div>

                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">
                        Aucun meuble disponible pour le moment.
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>

</div>
{% endblock %}