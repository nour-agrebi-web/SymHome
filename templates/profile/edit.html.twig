{% extends 'base.html.twig' %}

{% block title %}Modifier mon compte - SymHome{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: #fffdfb;
    }

    .edit-page {
        padding: 60px 0;
    }

    .edit-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.08);
    }

    .edit-header {
        background: linear-gradient(135deg, #8b5e3c, #5b3a25);
        color: white;
        padding: 28px;
    }

    .edit-header h1 {
        margin: 0;
        font-size: 30px;
        font-weight: 900;
    }

    .edit-body {
        background: white;
        padding: 34px;
    }

    .form-label {
        font-weight: 700;
        color: #392e2c;
    }

    .form-control {
        border-radius: 12px;
        height: 48px;
        border: 1px solid #ddd5cf;
    }

    textarea.form-control {
        height: 110px;
    }

    .form-control:focus {
        border-color: #8b5e3c;
        box-shadow: 0 0 0 0.2rem rgba(139, 94, 60, 0.18);
    }

    .btn-symhome {
        background: #8b5e3c;
        color: white;
        border: none;
        font-weight: 700;
        border-radius: 10px;
        padding: 11px 18px;
    }

    .btn-symhome:hover {
        background: #70482d;
        color: white;
    }

    .btn-cancel {
        border-radius: 10px;
        padding: 11px 18px;
        font-weight: 700;
    }
</style>
{% endblock %}

{% block body %}
<div class="container edit-page">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="edit-card">
                <div class="edit-header">
                    <h1>Modifier mes informations</h1>
                </div>

                <div class="edit-body">
                    <form method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nom</label>
                                <input type="text" name="nom" class="form-control" value="{{ user.nom }}" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Prénom</label>
                                <input type="text" name="prenom" class="form-control" value="{{ user.prenom }}" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Téléphone</label>
                            <input type="text" name="telephone" class="form-control" value="{{ user.telephone }}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Adresse</label>
                            <textarea name="adresse" class="form-control">{{ user.adresse }}</textarea>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-symhome">
                                Enregistrer
                            </button>

                            <a href="{{ path('app_profile') }}" class="btn btn-secondary btn-cancel">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}