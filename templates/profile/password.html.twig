{% extends 'base.html.twig' %}

{% block title %}Changer mot de passe - SymHome{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: #fffdfb;
    }

    .password-page {
        padding: 60px 0;
    }

    .password-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.08);
    }

    .password-header {
        background: linear-gradient(135deg, #8b5e3c, #5b3a25);
        color: white;
        padding: 28px;
    }

    .password-header h1 {
        margin: 0;
        font-size: 30px;
        font-weight: 900;
    }

    .password-body {
        background: white;
        padding: 34px;
    }

    .form-label {
        font-weight: 700;
        color: #392e2c;
    }

    .form-control {
        border-radius: 12px;
        height: 48px;
        border: 1px solid #ddd5cf;
    }

    .form-control:focus {
        border-color: #8b5e3c;
        box-shadow: 0 0 0 0.2rem rgba(139, 94, 60, 0.18);
    }

    .btn-symhome {
        background: #8b5e3c;
        color: white;
        border: none;
        font-weight: 700;
        border-radius: 10px;
        padding: 11px 18px;
    }

    .btn-symhome:hover {
        background: #70482d;
        color: white;
    }

    .btn-cancel {
        border-radius: 10px;
        padding: 11px 18px;
        font-weight: 700;
    }
</style>
{% endblock %}

{% block body %}
<div class="container password-page">

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="password-card">
                <div class="password-header">
                    <h1>Changer mot de passe</h1>
                </div>

                <div class="password-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Mot de passe actuel</label>
                            <input type="password" name="current_password" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nouveau mot de passe</label>
                            <input type="password" name="new_password" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirmer le nouveau mot de passe</label>
                            <input type="password" name="confirm_password" class="form-control" required>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-symhome">
                                Modifier
                            </button>

                            <a href="{{ path('app_profile') }}" class="btn btn-secondary btn-cancel">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}