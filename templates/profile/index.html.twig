{% extends 'base.html.twig' %}

{% block title %}Mon compte - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="mb-4">
                <h1 class="fw-bold text-center mb-4">Espace Comptes</h1>
                
            </div>

            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header text-white py-4" style="background: linear-gradient(135deg, #8b5e3c, #5b3a25);">
                    <h4 class="mb-0">Informations personnelles</h4>
                </div>

                <div class="card-body p-4">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Nom</small>
                                <div class="fw-bold fs-5">
                                    {{ app.user.nom }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Prénom</small>
                                <div class="fw-bold fs-5">
                                    {{ app.user.prenom }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Email</small>
                                <div class="fw-bold fs-5">
                                    {{ app.user.email }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted">Téléphone</small>
                                <div class="fw-bold fs-5">
                                    {{ app.user.telephone ?: '-' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted">Adresse</small>
                                <div class="fw-bold fs-5">
                                    {{ app.user.adresse ?: '-' }}
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>
<style>
  
</style>
{% endblock %}
