{% extends 'base.html.twig' %}

{% block title %}Mon compte - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="fw-bold mb-4">Mon espace client</h1>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            Informations personnelles
        </div>

        <div class="card-body">
            <p><strong>Nom :</strong> {{ app.user.nom }}</p>
            <p><strong>Prénom :</strong> {{ app.user.prenom }}</p>
            <p><strong>Email :</strong> {{ app.user.email }}</p>
            <p><strong>Téléphone :</strong> {{ app.user.telephone ?: '-' }}</p>
            <p><strong>Adresse :</strong> {{ app.user.adresse ?: '-' }}</p>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_commande_historique') }}" class="btn btn-outline-primary">
                    Mes commandes
                </a>

                <a href="{{ path('app_logout') }}" class="btn btn-danger">
                    Déconnexion
                </a>
            </div>
        </div>
    </div>

</div>
{% endblock %}
