{% extends 'base.html.twig' %}

{% block title %}Confirmation commande - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">
    <style>
        .alert-success.symhome { background:#f3eee8; color:#70482d; border:1px solid #eadfd5; border-radius:12px; padding:18px }
        .card-header-symhome{ background:#8b5e3c; color:#fff; padding:14px 18px; border-top-left-radius:12px; border-top-right-radius:12px }
        .btn-symhome{ background:#8b5e3c; color:#fff; border:none; padding:8px 12px; border-radius:10px; font-weight:700 }
        .btn-outline-symhome{ border:1px solid #8b5e3c; color:#8b5e3c; background:transparent; padding:7px 12px; border-radius:10px; font-weight:700 }
    </style>

    <div class="alert alert-success symhome shadow-sm">
        <h1 class="fw-bold">Commande confirmée</h1>
        <p class="mb-0">Votre commande a été validée avec succès.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header card-header-symhome">
            Récapitulatif de la commande
        </div>

        <div class="card-body">
            <p>
                <strong>Numéro commande :</strong>
                {{ commande.numero }}
            </p>

            <p>
                <strong>Date :</strong>
                {{ commande.createdAt|date('d/m/Y H:i') }}
            </p>

            <p>
                <strong>État :</strong>

                {% if commande.etat == 'en_attente' %}
                    <span class="badge bg-warning text-dark">En attente</span>
                {% elseif commande.etat == 'confirmee' %}
                    <span class="badge bg-success">Confirmée</span>
                {% elseif commande.etat == 'annulee' %}
                    <span class="badge bg-danger">Annulée</span>
                {% else %}
                    <span class="badge bg-secondary">{{ commande.etat }}</span>
                {% endif %}
            </p>

            <p>
                <strong>Paiement :</strong>
                {% if commande.isPaid %}
                    <span class="badge bg-success">Payée</span>
                {% else %}
                    <span class="badge bg-danger">Non payée</span>
                {% endif %}
            </p>

            <hr>

            <h4 class="mb-3">Produits commandés</h4>

            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Produit</th>
                        <th>Prix unitaire</th>
                        <th>Quantité</th>
                        <th>Sous-total</th>
                    </tr>
                </thead>

                <tbody>
                    {% for ligne in commande.ligneCommandes %}
                        <tr>
                            <td>{{ ligne.meuble.nom }}</td>
                            <td>{{ ligne.prixUnitaire }} DT</td>
                            <td>{{ ligne.quantite }}</td>
                            <td>{{ ligne.sousTotal }} DT</td>
                        </tr>
                    {% endfor %}
                </tbody>

                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Total</th>
                        <th>{{ commande.total }} DT</th>
                    </tr>
                </tfoot>
            </table>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_home') }}" class="btn-symhome">
                    Retour à l'accueil
                </a>

                <a href="{{ path('app_commande_historique') }}" class="btn-outline-symhome">
                    Mes commandes
                </a>
            </div>
        </div>
    </div>

</div>
{% endblock %}