{% extends 'base.html.twig' %}

{% block title %}Mes commandes - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="fw-bold mb-2">Mes commandes</h1>
    <p class="text-muted mb-4">Historique des commandes passées.</p>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {% if commandes|length > 0 %}
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Numéro</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>État</th>
                            <th>Paiement</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for commande in commandes %}
                            <tr>
                                <td>
                                    <strong>{{ commande.numero }}</strong>
                                </td>
                                <td>{{ commande.createdAt|date('d/m/Y H:i') }}</td>
                                <td>{{ commande.total }} DT</td>
                                <td>
                                    {% if commande.etat == 'en_attente' %}
                                        <span class="badge bg-warning text-dark">En attente</span>
                                    {% elseif commande.etat == 'confirmee' %}
                                        <span class="badge bg-success">Confirmée</span>
                                    {% elseif commande.etat == 'annulee' %}
                                        <span class="badge bg-danger">Annulée</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ commande.etat }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if commande.isPaid %}
                                        <span class="badge bg-success">Payée</span>
                                    {% else %}
                                        <span class="badge bg-danger">Non payée</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_commande_detail', {'id': commande.id}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        Détails
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info">
            Aucune commande trouvée.
        </div>
    {% endif %}

</div>
{% endblock %}