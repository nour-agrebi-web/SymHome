{% extends 'base.html.twig' %}

{% block title %}Gestion utilisateurs - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="fw-bold mb-2">Gestion des utilisateurs</h1>
    <p class="text-muted mb-4">Liste des clients inscrits sur SymHome.</p>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Client</th>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>Téléphone</th>
                        <th>Date création</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>
                                <strong>{{ user.nom }} {{ user.prenom }}</strong>
                            </td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% for role in user.roles %}
                                    <span class="badge bg-secondary">{{ role }}</span>
                                {% endfor %}
                            </td>
                            <td>{{ user.telephone ?: '-' }}</td>
                            <td>
                                {% if user.createdAt %}
                                    {{ user.createdAt|date('d/m/Y H:i') }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('app_admin_user_show', {'id': user.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Voir
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                Aucun utilisateur trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}