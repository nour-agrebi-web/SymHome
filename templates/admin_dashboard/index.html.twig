{% extends 'admin_base.html.twig' %}

{% block title %}Dashboard Admin - SymHome{% endblock %}

{% block body %}

    <h1 class="admin-title">Dashboard Admin</h1>
    <p class="admin-description">Résumé simple de l'activité de la boutique SymHome.</p>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <h6>Clients</h6>
                <h2>{{ nombreClients }}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <h6>Meubles</h6>
                <h2>{{ nombreMeubles }}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <h6>Commandes</h6>
                <h2>{{ nombreCommandes }}</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <h6>Chiffre d'affaires</h6>
                <h2>{{ chiffreAffaires }} DT</h2>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    Meuble le plus vendu
                </div>

                <div class="admin-card-body">
                    <h3 class="fw-bold">{{ meublePlusVendu }}</h3>
                    <p class="text-muted mb-0">
                        Produit avec la quantité vendue la plus élevée.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    État des commandes
                </div>

                <div class="admin-card-body">
                    <canvas id="commandesChart" height="120"></canvas>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx = document.getElementById('commandesChart');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['En attente', 'Confirmées', 'Annulées'],
            datasets: [{
                label: 'Nombre de commandes',
                data: [
                    {{ commandesEnAttente }},
                    {{ commandesConfirmees }},
                    {{ commandesAnnulees }}
                ],
                backgroundColor: '#8b5e3c'
            }]
        }
    });
</script>
{% endblock %}
{% endblock %}