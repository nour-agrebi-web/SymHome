{% extends 'admin_base.html.twig' %}

{% block title %}Modifier un meuble{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Modifier le meuble</h4>
                </div>

                <div class="card-body">
                    {{ include('meuble/_form.html.twig', {
                        'button_label': 'Modifier'
                    }) }}
                </div>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a href="{{ path('app_meuble_index') }}" class="btn btn-outline-secondary">
                    Retour à la liste
                </a>

                {{ include('meuble/_delete_form.html.twig') }}
            </div>

        </div>
    </div>

</div>
{% endblock %}