{% extends 'admin_base.html.twig' %}

{% block title %}Détail meuble{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Détail du meuble</h4>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    {% if meuble.image %}
                        <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                             alt="{{ meuble.nom }}"
                             class="img-fluid rounded border">
                    {% else %}
                        <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                             style="height: 250px;">
                            <span class="text-muted">Aucune image</span>
                        </div>
                    {% endif %}
                </div>

                <div class="col-md-8">
                    <table class="table">
                        <tbody>
                            <tr>
                                <th style="width: 200px;">ID</th>
                                <td>{{ meuble.id }}</td>
                            </tr>
                            <tr>
                                <th>Nom</th>
                                <td>{{ meuble.nom }}</td>
                            </tr>
                            <tr>
                                <th>Description</th>
                                <td>
                                    {% if meuble.description %}
                                        {{ meuble.description }}
                                    {% else %}
                                        <span class="text-muted">Aucune description</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Prix</th>
                                <td>{{ meuble.prix }} DT</td>
                            </tr>
                            <tr>
                                <th>Stock disponible</th>
                                <td>
                                    {% if meuble.stock >= 10 %}
                                        <span class="badge bg-success">{{ meuble.stock }}</span>
                                    {% elseif meuble.stock >= 6 %}
                                        <span class="badge bg-warning text-dark">{{ meuble.stock }}</span>
                                    {% elseif meuble.stock > 0 %}
                                        <span class="badge bg-danger">{{ meuble.stock }}</span>
                                    {% else %}
                                        <span class="badge bg-danger">Rupture</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Catégorie</th>
                                <td>
                                    {% if meuble.categorie %}
                                        {{ meuble.categorie.nom }}
                                    {% else %}
                                        <span class="text-muted">Sans catégorie</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Image</th>
                                <td>
                                    {% if meuble.image %}
                                        {{ meuble.image }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Date création</th>
                                <td>
                                    {% if meuble.createdAt %}
                                        {{ meuble.createdAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Dernière modification</th>
                                <td>
                                    {% if meuble.updatedAt %}
                                        {{ meuble.updatedAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}