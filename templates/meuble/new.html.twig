{% extends 'admin_base.html.twig' %}

{% block title %}Ajouter un meuble{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="admin-card">
            <div class="admin-card-header">
                Ajouter un meuble
            </div>

            <div class="admin-card-body">
                {{ include('meuble/_form.html.twig', {
                    'button_label': 'Ajouter'
                }) }}
            </div>
        </div>

        <a href="{{ path('app_meuble_index') }}" class="btn btn-outline-secondary mt-3">
            Retour à la liste
        </a>

    </div>
</div>
{% endblock %}