{% extends 'admin_base.html.twig' %}

{% block title %}Gestion des meubles{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Gestion des meubles</h1>
            <p class="text-muted">Liste des meubles disponibles dans le catalogue.</p>
        </div>

        <a href="{{ path('app_meuble_new') }}" class="btn btn-admin">
            Ajouter un meuble
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Nom</th>
                        <th>Catégorie</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for meuble in meubles %}
                    <tr>
                        <td>{{ meuble.id }}</td>

                        <td>
                            {% if meuble.image %}
                                <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                                     alt="{{ meuble.nom }}"
                                     style="width: 70px; height: 55px; object-fit: cover;"
                                     class="rounded border">
                            {% else %}
                                <span class="text-muted">Aucune image</span>
                            {% endif %}
                        </td>

                        <td>
                            <strong>{{ meuble.nom }}</strong>
                            <br>
                            <small class="text-muted">
                                {% if meuble.description %}
                                    {{ meuble.description|slice(0, 45) }}
                                    {% if meuble.description|length > 45 %}...{% endif %}
                                {% else %}
                                    Aucune description
                                {% endif %}
                            </small>
                        </td>

                        <td>
                            {% if meuble.categorie %}
                                <span class="badge bg-secondary">{{ meuble.categorie.nom }}</span>
                            {% else %}
                                <span class="text-muted">Sans catégorie</span>
                            {% endif %}
                        </td>

                        <td>{{ meuble.prix }} DT</td>

                        <td>
                            {% if meuble.stock >= 10 %}
                                <span class="badge bg-success">{{ meuble.stock }}</span>
                            {% elseif meuble.stock >= 6 %}
                                <span class="badge bg-warning text-dark">{{ meuble.stock }}</span>
                            {% elseif meuble.stock > 0 %}
                                <span class="badge bg-danger">{{ meuble.stock }}</span>
                            {% else %}
                                <span class="badge bg-danger">Rupture</span>
                            {% endif %}
                        </td>

                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_meuble_show', {'id': meuble.id}) }}" class="btn btn-sm btn-info text-white">
                                    Voir
                                </a>

                                <a href="{{ path('app_meuble_edit', {'id': meuble.id}) }}" class="btn btn-sm btn-warning">
                                    Modifier
                                </a>

                                <form method="post"
                                      action="{{ path('app_meuble_delete', {'id': meuble.id}) }}"
                                      onsubmit="return confirm('Voulez-vous vraiment supprimer ce meuble ?');"
                                      class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ meuble.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Aucun meuble trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}