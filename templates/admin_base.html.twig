<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Admin - SymHome{% endblock %}</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

        <style>
            body {
                margin: 0;
                background: #f7f3ee;
                font-family: Arial, sans-serif;
            }

            .admin-layout {
                display: flex;
                min-height: 100vh;
            }

            .admin-sidebar {
                width: 270px;
                background: #ffffff;
                border-right: 1px solid #eadfd5;
                padding: 28px 22px;
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
            }

            .admin-logo {
                font-size: 32px;
                font-weight: 900;
                color: #70482d;
                margin-bottom: 8px;
            }

            .admin-subtitle {
                color: #7a6a5d;
                margin-bottom: 35px;
            }

            .admin-menu a {
                display: block;
                text-decoration: none;
                color: #2b2118;
                font-weight: 700;
                padding: 15px 18px;
                border-radius: 12px;
                margin-bottom: 10px;
                transition: 0.2s;
            }

            .admin-menu a:hover,
            .admin-menu a.active {
                background: #f3eee8;
                color: #8b5e3c;
            }

            .admin-menu .logout {
                color: #dc3545;
                border-top: 1px solid #eee;
                margin-top: 25px;
                padding-top: 20px;
            }

            .admin-content {
                margin-left: 270px;
                padding: 45px 55px;
                width: calc(100% - 270px);
            }

            .admin-title {
                font-size: 42px;
                font-weight: 900;
                color: #2b2118;
                margin-bottom: 8px;
            }

            .admin-description {
                color: #6f6257;
                font-size: 18px;
                margin-bottom: 30px;
            }

            .stat-card {
                background: white;
                border-radius: 20px;
                border: 1px solid #eadfd5;
                padding: 25px;
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            }

            .stat-card h6 {
                color: #8b5e3c;
                font-weight: 800;
                margin-bottom: 12px;
            }

            .stat-card h2 {
                font-weight: 900;
                color: #2b2118;
            }

            .admin-card {
                background: white;
                border-radius: 22px;
                border: 1px solid #eadfd5;
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
                overflow: hidden;
            }

            .admin-card-header {
                background: #70482d;
                color: white;
                padding: 18px 24px;
                font-weight: 800;
                font-size: 18px;
            }

            .admin-card-body {
                padding: 24px;
            }

            .btn-admin {
                background: #8b5e3c;
                border: none;
                color: white;
                font-weight: 700;
            }

            .btn-admin:hover {
                background: #70482d;
                color: white;
            }

            .table-dark {
                --bs-table-bg: #70482d;
            }

            @media (max-width: 992px) {
                .admin-sidebar {
                    position: static;
                    width: 100%;
                    height: auto;
                }

                .admin-layout {
                    display: block;
                }

                .admin-content {
                    margin-left: 0;
                    width: 100%;
                    padding: 30px 20px;
                }
            }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        <div class="admin-layout">

            <aside class="admin-sidebar">
                <div class="admin-logo">SymHome</div>
                <div class="admin-subtitle">Espace Administrateur</div>

                <nav class="admin-menu">
                    <a href="{{ path('app_admin_dashboard') }}">Tableau de bord</a>
                    <a href="{{ path('app_categorie_index') }}">Catégories</a>
                    <a href="{{ path('app_meuble_index') }}">Meubles</a>
                    <a href="{{ path('app_admin_commande_index') }}">Commandes</a>
                    <a href="{{ path('app_admin_user_index') }}">Utilisateurs</a>

                    <a href="{{ path('app_home') }}">Retour au site</a>
                    <a href="{{ path('app_logout') }}" class="logout">Se déconnecter</a>
                </nav>
            </aside>

            <main class="admin-content">
                {% block body %}{% endblock %}
            </main>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>