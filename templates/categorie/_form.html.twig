{{ form_start(form) }}

    <div class="mb-3">
        {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        <div class="text-danger">
            {{ form_errors(form.nom) }}
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
        <div class="text-danger">
            {{ form_errors(form.description) }}
        </div>
    </div>

    <button class="btn btn-admin px-4">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}