{% extends 'base.html.twig' %}

{% block title %}Détail catégorie{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Détail de la catégorie</h4>
        </div>

        <div class="card-body">
            <table class="table">
                <tbody>
                    <tr>
                        <th style="width: 200px;">ID</th>
                        <td>{{ categorie.id }}</td>
                    </tr>
                    <tr>
                        <th>Nom</th>
                        <td>{{ categorie.nom }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>
                            {% if categorie.description %}
                                {{ categorie.description }}
                            {% else %}
                                <span class="text-muted">Aucune description</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Date création</th>
                        <td>
                            {% if categorie.createdAt is defined and categorie.createdAt %}
                                {{ categorie.createdAt|date('d/m/Y H:i') }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex justify-content-between">
                <div>
                    <a href="{{ path('app_categorie_index') }}" class="btn btn-outline-secondary">
                        Retour
                    </a>

                    <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-warning">
                        Modifier
                    </a>
                </div>

                {{ include('categorie/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

</div>
{% endblock %}