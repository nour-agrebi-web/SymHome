{% extends 'base.html.twig' %}

{% block title %}Gestion des catégories{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Gestion des catégories</h1>
            <p class="text-muted">Liste des catégories de meubles.</p>
        </div>

        <a href="{{ path('app_categorie_new') }}" class="btn btn-primary">
            Ajouter une catégorie
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for categorie in categories %}
                    <tr>
                        <td>{{ categorie.id }}</td>
                        <td>
                            <strong>{{ categorie.nom }}</strong>
                        </td>
                        <td>
                            {% if categorie.description %}
                                {{ categorie.description|slice(0, 80) }}
                                {% if categorie.description|length > 80 %}...{% endif %}
                            {% else %}
                                <span class="text-muted">Aucune description</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="btn btn-sm btn-info text-white">
                                Voir
                            </a>

                            <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-sm btn-warning">
                                Modifier
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            Aucune catégorie trouvée.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <a href="#" class="btn btn-outline-secondary mt-3">
    Retour
</a>
</div>
{% endblock %}