<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Maisons du Monde{% endblock %}</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

        <style>
            .main-navbar {
                background: #392e2c;
                padding: 18px 0;
            }

            .brand-logo {
                color: #ffffff;
                text-decoration: none;
                font-weight: 900;
                font-size: 26px;
                letter-spacing: 1px;
                line-height: 1;
                text-align: center;
            }

            .brand-logo span {
                display: block;
                font-size: 11px;
                letter-spacing: 6px;
                font-weight: 700;
                margin-top: 5px;
            }

            .navbar-nav {
                align-items: center;
            }

            .navbar-nav .nav-link {
                color: #ffffffcc !important;
                font-weight: 600;
                margin-left: 18px;
                font-size: 15px;
            }

            .navbar-nav .nav-link:hover {
                color: #ffffff !important;
            }

            .account-link {
                display: flex !important;
                align-items: center;
                gap: 8px;
                line-height: 1.1;
            }

            .account-link i {
                font-size: 30px;
                color: white;
            }

            .account-link small {
                display: block;
                color: #ffffff;
                font-size: 12px;
                font-weight: 800;
            }

            .account-link span {
                display: block;
                color: #ffffffcc;
                font-size: 12px;
                font-weight: 600;
            }

            .cart-link i {
                font-size: 30px;
                color: white;
            }

            .navbar-toggler {
                border-color: rgba(255, 255, 255, 0.35);
            }

            .dropdown-menu {
                border: none;
                border-radius: 14px;
                padding: 10px;
                box-shadow: 0 14px 35px rgba(0, 0, 0, 0.15);
            }

            .dropdown-item {
                border-radius: 10px;
                font-weight: 600;
                padding: 10px 14px;
            }

            .dropdown-item:hover {
                background: #f3eee8;
                color: #70482d;
            }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        {% block navbar %}
            <nav class="navbar navbar-expand-lg navbar-dark main-navbar">
                <div class="container">
                    <a class="brand-logo" href="{{ path('app_home') }}">
                        MAISONS
                        <span>DU MONDE</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSymHome">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSymHome">
                        <ul class="navbar-nav ms-auto">

                            {% if app.user %}
                                <li class="nav-item">
