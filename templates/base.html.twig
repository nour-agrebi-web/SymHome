<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SymHome{% endblock %}</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">SymHome</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSymHome">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSymHome">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_produit_index') }}">Produits</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_panier_index') }}">Panier</a>
                        </li>

                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_commande_historique') }}">Mes commandes</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_profile') }}">Mon compte</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" href="{{ path('app_logout') }}">Déconnexion</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
                            </li>
                        {% endif %}

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Administration
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_admin_dashboard') }}">
                                        Dashboard
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_categorie_index') }}">
                                        Catégories
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_meuble_index') }}">
                                        Meubles
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_admin_commande_index') }}">
                                        Commandes
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="{{ path('app_admin_user_index') }}">
                                        Utilisateurs
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>