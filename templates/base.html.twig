                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_commande_historique') }}">
                                        Mes commandes
                                    </a>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link account-link dropdown-toggle"
                                       href="#"
                                       role="button"
