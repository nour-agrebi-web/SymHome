{% extends 'base.html.twig' %}

{% block title %}Détail produit - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary mb-4">
        Retour à l'accueil
    </a>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row">

                <div class="col-md-5">
                    {% if meuble.image %}
                        <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                             alt="{{ meuble.nom }}"
                             class="img-fluid rounded border"
                             style="width: 100%; max-height: 420px; object-fit: cover;">
                    {% else %}
                        <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                             style="height: 350px;">
                            <span class="text-muted">Aucune image</span>
                        </div>
                    {% endif %}
                </div>

                <div class="col-md-7">
                    {% if meuble.categorie %}
                        <span class="badge bg-secondary mb-3">
                            {{ meuble.categorie.nom }}
                        </span>
                    {% endif %}

                    <h1 class="fw-bold">{{ meuble.nom }}</h1>

                    <p class="text-muted mt-3">
                        {% if meuble.description %}
                            {{ meuble.description }}
                        {% else %}
                            Aucune description disponible.
                        {% endif %}
                    </p>

                    <h3 class="text-primary fw-bold mt-4">
                        {{ meuble.prix }} DT
                    </h3>

                    <div class="mt-3">
                        {% if meuble.stock > 0 %}
                            <span class="badge bg-success fs-6">
                                Stock disponible : {{ meuble.stock }}
                            </span>
                        {% else %}
                            <span class="badge bg-danger fs-6">
                                Rupture de stock
                            </span>
                        {% endif %}
                    </div>

                    <hr>

                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-success btn-lg">
                            Ajouter au panier
                        </a>

                        <a href="{{ path('app_panier_ajouter', {'id': meuble.id}) }}" class="btn btn-success btn-lg">
                            Ajouter au panier
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>
{% endblock %}