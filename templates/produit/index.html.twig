{% extends 'base.html.twig' %}

{% block title %}Produits - SymHome{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="fw-bold mb-2">Nos produits</h1>
    <p class="text-muted mb-4">Découvrez tous les meubles disponibles chez SymHome.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_produit_index') }}" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Recherche par nom</label>
                    <input type="text"
                           name="search"
                           value="{{ search }}"
                           class="form-control"
                           placeholder="Ex: canapé, chaise, bureau...">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Catégorie</label>
                    <select name="categorie" class="form-select">
                        <option value="">Toutes les catégories</option>

                        {% for categorie in categories %}
                            <option value="{{ categorie.id }}"
                                {% if categorieId == categorie.id %}selected{% endif %}>
                                {{ categorie.nom }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        Rechercher
                    </button>

                    <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        {% for meuble in meubles %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">

                    {% if meuble.image %}
                        <img src="{{ asset('uploads/meubles/' ~ meuble.image) }}"
                             class="card-img-top"
                             alt="{{ meuble.nom }}"
                             style="height: 220px; object-fit: cover;">
                    {% else %}
                        <div class="bg-light d-flex align-items-center justify-content-center"
                             style="height: 220px;">
                            <span class="text-muted">Aucune image</span>
                        </div>
                    {% endif %}

                    <div class="card-body">
                        {% if meuble.categorie %}
                            <span class="badge bg-secondary mb-2">
                                {{ meuble.categorie.nom }}
                            </span>
                        {% endif %}

                        <h5 class="card-title">{{ meuble.nom }}</h5>

                        <p class="card-text text-muted">
                            {% if meuble.description %}
                                {{ meuble.description|slice(0, 80) }}
                                {% if meuble.description|length > 80 %}...{% endif %}
                            {% else %}
                                Aucune description
                            {% endif %}
                        </p>

                        <p class="fw-bold text-primary fs-5">
                            {{ meuble.prix }} DT
                        </p>

                        {% if meuble.stock > 0 %}
                            <span class="badge bg-success">En stock: {{ meuble.stock }}</span>
                        {% else %}
                            <span class="badge bg-danger">Rupture de stock</span>
                        {% endif %}
                    </div>

                    <div class="card-footer bg-white d-flex justify-content-between">
                        <a href="{{ path('app_produit_show', {'id': meuble.id}) }}" class="btn btn-sm btn-outline-primary">
                            Voir détail
                        </a>

                        <a href="#" class="btn btn-sm btn-success">
                            Ajouter au panier
                        </a>
                    </div>

                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-warning">
                    Aucun produit trouvé.
                </div>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}